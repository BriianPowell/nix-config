# Shared SSH config for Linux, WSL, and other non-macOS hosts.
# macOS uses darwin.config (1Password agent).

Host *
  ServerAliveInterval 60
  TCPKeepAlive no

Host sheol
  HostName 10.0.2.10
  User boog

Host sheolInitrd
  HostName 10.0.2.10
  Port 2222
  User root

Host abaddon
  HostName 10.0.2.11
  User boog

Host abaddonInitrd
  HostName 10.0.2.11
  Port 2222
  User root

# git@github.com uses hostname github.com (not the "github" alias)
Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes
