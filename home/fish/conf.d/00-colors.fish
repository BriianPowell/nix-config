# Explicit fish colors (fish 4). No --theme=default — that uses the light
# theme on macOS Light appearance and makes predictive text backgrounds white.

set -g fish_color_autosuggestion brblack
set -g fish_color_search_match white --background=brblack

set -g fish_pager_color_background --background=brblack
set -g fish_pager_color_secondary_background --background=brblack
set -g fish_pager_color_selected_background --background=brblack
