Host *
  IdentityAgent ~/.1password/agent.sock
  ServerAliveInterval 60
  TCPKeepAlive no

# sheol / abaddon: keys from 1Password agent (order in agent.toml).
# Do not set IdentitiesOnly yes without IdentityFile — OpenSSH then ignores agent keys
# and only tries ~/.ssh/id_ed25519 etc. (see ssh -v "Will attempt key: .../.ssh/id_*").

Host abaddon
  HostName 10.0.2.11
  User boog

Host abaddonInitrd
  HostName 10.0.2.11
  Port 2222
  User root

Host sheol
  HostName 10.0.2.10
  User boog

Host sheolInitrd
  HostName 10.0.2.10
  Port 2222
  User root

# git@github.com uses hostname github.com (not the "github" alias)
Host github.com
  HostName github.com
  User git
