Host *
  IdentityAgent ~/.1password/agent.sock
  ServerAliveInterval 60
  TCPKeepAlive no

# sheol / abaddon: 1Password "NixOS Admin" (see home/config/1Password/ssh/agent.toml).
Host sheol abaddon sheolInitrd abaddonInitrd
  IdentitiesOnly yes

Host abaddon
  HostName 10.0.2.11
  User boog

Host abaddonInitrd
  HostName 10.0.2.11
  Port 2222
  User root

Host sheol
  HostName 10.0.2.10
  User boog

Host sheolInitrd
  HostName 10.0.2.10
  Port 2222
  User root

# git@github.com uses hostname github.com (not the "github" alias)
Host github.com
  HostName github.com
  User git
